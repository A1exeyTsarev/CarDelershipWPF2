<Page x:Class="CarDelershipWPF.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление товарами"
      Background="#1a1a1a">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление товарами" FontSize="24" FontWeight="Bold" 
                   Foreground="#FFC107" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Поиск товаров" Foreground="#FFC107" FontSize="11" 
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="txtSearchCounter" Foreground="#888" FontSize="10" 
                                   Margin="10,0,0,3" Visibility="Collapsed"/>
                    </StackPanel>
                    <TextBox x:Name="txtSearch" Tag="Введите название..."
                             Background="#333" Foreground="White" Height="35" Padding="5"
                             TextChanged="TxtSearch_TextChanged"
                             PreviewTextInput="TxtSearch_PreviewTextInput"
                             PreviewKeyDown="TxtSearch_PreviewKeyDown"
                             MaxLength="50"/>
                    <TextBlock x:Name="txtSearchError" Foreground="#FF6B6B" FontSize="10" 
                               Margin="0,2,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <Button x:Name="btnAdd" Grid.Column="1" Content="➕ Добавить" Width="100" Height="35"
                        Background="#FFC107" Foreground="Black" FontWeight="Bold"
                        Click="BtnAdd_Click" Margin="10,0,0,0" Cursor="Hand"/>

                <Button x:Name="btnBack" Grid.Column="2" Content="◀ Назад" Width="100" Height="35"
                        Background="#333" Foreground="#FFC107" FontWeight="Bold"
                        Click="BtnBack_Click" Margin="10,0,0,0" Cursor="Hand"/>
            </Grid>
        </Border>

        <DataGrid x:Name="dgProducts" Grid.Row="2" AutoGenerateColumns="False" 
                  SelectionMode="Single" IsReadOnly="True" 
                  Background="#2a2a2a" 
                  Foreground="White"
                  RowBackground="#2a2a2a"
                  AlternatingRowBackground="#333333"
                  BorderBrush="#404040"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  MouseDoubleClick="DgProducts_MouseDoubleClick">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FFC107"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderBrush" Value="#404040"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2a2a2a"/>
                    <Setter Property="BorderBrush" Value="#404040"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>

                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#2a2a2a"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#404040"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Колонка Фото -->
                <DataGridTemplateColumn Header="Фото" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="5" Background="#2a2a2a" 
                                    Height="50" Width="65" BorderBrush="#FFC107" BorderThickness="1"
                                    HorizontalAlignment="Center">
                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill" 
                                       Margin="2" Width="55" Height="40"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="ID" Binding="{Binding Car_Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N0}" Width="100"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding AvailabilityStatus}" Width="100"/>

                <DataGridTemplateColumn Header="Действия" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✏️" Width="30" Height="30"
                                    Click="BtnEdit_Click" Tag="{Binding}" 
                                    Background="#FFC107" Foreground="Black" Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>