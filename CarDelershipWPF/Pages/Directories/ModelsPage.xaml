<Page x:Class="CarDelershipWPF.Pages.Directories.ModelsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Модели авто"
      Background="#1a1a1a">

    <Page.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление моделями" FontSize="24" FontWeight="Bold" 
                   Foreground="#FFC107" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Кнопки управления -->
        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnAdd" Content="➕ Добавить модель" Width="150" Height="35"
                        Background="#FFC107" Foreground="Black" FontWeight="Bold"
                        Click="BtnAdd_Click" Margin="5" Cursor="Hand"/>
                <Button x:Name="btnBack" Content="◀ Назад" Width="100" Height="35"
                        Background="#333" Foreground="#FFC107" FontWeight="Bold"
                        Click="BtnBack_Click" Margin="5" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Таблица моделей - упрощенная версия без InputBindings -->
        <DataGrid x:Name="dgItems" Grid.Row="2" AutoGenerateColumns="True" 
                  SelectionMode="Single" IsReadOnly="True"
                  Background="#2a2a2a" Foreground="White"
                  RowBackground="#2a2a2a" AlternatingRowBackground="#333333"
                  BorderBrush="#404040"
                  MouseDoubleClick="DgItems_MouseDoubleClick"/>
    </Grid>
</Page>