<Page x:Class="CarDelershipWPF.Pages.Directories.DirectoriesMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Справочники"
      Background="#1a1a1a">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Управление справочниками" FontSize="24" FontWeight="Bold" 
                       Foreground="#FFC107" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Производители -->
                <Button x:Name="btnManufacturers" Content="🏭 Производители" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnManufacturers_Click" Cursor="Hand"/>

                <!-- Модели авто -->
                <Button x:Name="btnModels" Content="🚗 Модели авто" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnModels_Click" Cursor="Hand"/>

                <!-- Цвета -->
                <Button x:Name="btnColors" Content="🎨 Цвета" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnColors_Click" Cursor="Hand"/>

                <!-- Типы кузова -->
                <Button x:Name="btnBodyTypes" Content="🚙 Типы кузова" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnBodyTypes_Click" Cursor="Hand"/>

                <!-- Типы двигателя -->
                <Button x:Name="btnEngineTypes" Content="⚙️ Типы двигателя" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnEngineTypes_Click" Cursor="Hand"/>

                <!-- КПП -->
                <Button x:Name="btnTransmissions" Content="🔧 КПП" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnTransmissions_Click" Cursor="Hand"/>

                <!-- ПОЛЬЗОВАТЕЛИ (НОВЫЙ СПРАВОЧНИК) -->
                <Button x:Name="btnUsers" Content="👥 Пользователи" Width="200" Height="80" Margin="10"
                        Background="#FFC107" Foreground="Black" FontSize="14" FontWeight="Bold"
                        Click="BtnUsers_Click" Cursor="Hand"/>

                <!-- Кнопка Назад -->
                <Button x:Name="btnBack" Content="◀ Назад" Width="200" Height="50" Margin="10"
                        Background="#333" Foreground="#FFC107" FontSize="14" FontWeight="Bold"
                        Click="BtnBack_Click" Cursor="Hand"/>
            </WrapPanel>
        </Grid>
    </ScrollViewer>
</Page>