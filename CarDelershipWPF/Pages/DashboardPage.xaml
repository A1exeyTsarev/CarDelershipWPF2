<Page x:Class="CarDelershipWPF.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель управления"
      Background="#1a1a1a">

    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Приветствие -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                <TextBlock Text="Панель управления" FontSize="28" FontWeight="Bold" 
                           Foreground="#FFC107" TextAlignment="Center"/>
                <TextBlock x:Name="txtWelcome" FontSize="14" Foreground="#888" 
                           TextAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Меню -->
            <WrapPanel Grid.Row="1" HorizontalAlignment="Center">

                <!-- Товары -->
                <Border Background="#2a2a2a" CornerRadius="10" Width="220" Height="120" Margin="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🚗" FontSize="36" TextAlignment="Center"/>
                        <TextBlock Text="Товары" FontSize="16" FontWeight="Bold" Foreground="#FFC107" TextAlignment="Center"/>
                        <Button Content="Управление товарами" Background="#FFC107" Foreground="Black" 
                                FontWeight="Bold" Margin="10,5" Click="BtnProducts_Click" Cursor="Hand"/>
                        <Button Content="История цен" Background="#333" Foreground="#FFC107" 
                                Margin="10,5" Click="BtnPriceHistory_Click" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Справочники -->
                <Border Background="#2a2a2a" CornerRadius="10" Width="220" Height="120" Margin="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📚" FontSize="36" TextAlignment="Center"/>
                        <TextBlock Text="Справочники" FontSize="16" FontWeight="Bold" Foreground="#FFC107" TextAlignment="Center"/>
                        <Button Content="Управление справочниками" Background="#FFC107" Foreground="Black" 
                                FontWeight="Bold" Margin="10,5" Click="BtnDirectories_Click" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Заказы -->
                <Border Background="#2a2a2a" CornerRadius="10" Width="220" Height="120" Margin="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="36" TextAlignment="Center"/>
                        <TextBlock Text="Заказы" FontSize="16" FontWeight="Bold" Foreground="#FFC107" TextAlignment="Center"/>
                        <Button Content="Управление заказами" Background="#FFC107" Foreground="Black" 
                                FontWeight="Bold" Margin="10,5" Click="BtnOrders_Click" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Поставки -->
                <Border Background="#2a2a2a" CornerRadius="10" Width="220" Height="120" Margin="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🚚" FontSize="36" TextAlignment="Center"/>
                        <TextBlock Text="Поставки" FontSize="16" FontWeight="Bold" Foreground="#FFC107" TextAlignment="Center"/>
                        <Button Content="Управление поставками" Background="#FFC107" Foreground="Black" 
                                FontWeight="Bold" Margin="10,5" Click="BtnSupplies_Click" Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Кнопка выхода -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,40,0,0">
                <Button x:Name="btnLogout" Content="Выйти из системы" Width="200" Height="40"
                        Background="#DC3545" Foreground="White" FontWeight="Bold"
                        Click="BtnLogout_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>